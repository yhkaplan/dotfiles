# Docs: https://ghostty.org/docs/config/reference
font-family = Source Code Pro for Powerline
font-family-bold = Source Code Pro Bold for Powerline
font-style-italic = Source Code Pro Italic for Powerline
font-style-bold-italic = Source Code Pro Bold Italic for Powerline
font-size = 15

# Check themes with command below
# ls /Applications/Ghostty.app/Contents/Resources/ghostty/themes
# or ghostty +list-themes
# CobaltNext-Dark, Dracula, GitHub-Dark-High-Constrast, tokyonight_night, xcodedarkhc
theme = TokyoNight Night

title = " "
macos-titlebar-style = tabs
# blueprint, chalkboard, microchip, glass, holographic, paper, retro, xray
macos-icon = chalkboard

window-padding-x = 6
window-padding-y = 0

cursor-style = block
cursor-style-blink = false
keybind = shift+enter=text:\x1b\r

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

